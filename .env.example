# Required
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-5o-mini
SUMMARY_MODEL=gpt-4.1-mini
SUMMARY_TRIGGER_TOKENS=12000
SUMMARY_TRIGGER_MESSAGES=80
SUMMARY_KEEP_MESSAGES=30
TOOL_CALL_THREAD_LIMIT=200
TOOL_CALL_RUN_LIMIT=40

# Tracing backend selector: langsmith | langfuse | jsonl | none
TRACING_BACKEND=langsmith
TRACE_JSONL_PATH=./backend/traces/agent-runtime.jsonl
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/arc_agent
POSTGRES_URI_DOCKER=postgresql://postgres:postgres@postgres:5432/arc_agent
PREFERENCES_DB_PATH=./backend/.arc_agent_prefs.sqlite
NEXT_PUBLIC_API_URL=http://localhost:2024
NEXT_PUBLIC_ASSISTANT_ID=agent
ARC_MCP_TRANSPORT=sse
ARC_MCP_HOST=127.0.0.1
ARC_MCP_PORT=8765
ARC_MCP_SSE_URL=http://127.0.0.1:8765/sse
ARC_MCP_SSE_URL_DOCKER=http://host.docker.internal:8765/sse

# Optional
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# LangSmith (tracing)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=arc-agent
LANGSMITH_WORKSPACE_ID=your_langsmith_workspace_id_here
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com  # EU instance only

# Langfuse (tracing, when TRACING_BACKEND=langfuse)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
