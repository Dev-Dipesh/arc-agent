# Required
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-5o-mini
SUMMARY_MODEL=gpt-4.1-mini

# Tracing backend selector: langsmith | langfuse | jsonl | none
TRACING_BACKEND=langsmith
TRACE_JSONL_PATH=./backend/traces/agent-runtime.jsonl

# Optional
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Runtime persistence for LangGraph server mode (recommended for durable threads)
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/arc_agent

# Local long-term preference storage
PREFERENCES_DB_PATH=./backend/.arc_agent_prefs.sqlite

# LangSmith (tracing)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=arc-agent
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com  # EU instance only

# Langfuse (tracing, when TRACING_BACKEND=langfuse)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
